{
  /**
   * Configuración de TypeScript para el proyecto.
   * - Soporte JSX para React.
   * - Target ES2020 con módulos ESNext.
   * - Path alias '@' para imports desde src/.
   * - Strict mode deshabilitado para flexibilidad.
   * - Optimizado para bundler (Vite).
   */
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "*.config.ts", "*.config.js"]
}